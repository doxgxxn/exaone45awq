{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "excel": {
      "type": "local",
      "command": ["npx", "-y", "@negokaz/excel-mcp-server"],
      "enabled": true,
      "env": {
        "EXCEL_MCP_PAGING_CELLS_LIMIT": "4000"
      }
    },
    "markitdown": {
      "type": "local",
      "command": ["./.venv/bin/markitdown-mcp"],
      "enabled": true,
      "env": {}
    }
  }
}
